[Unit]
Description=DronePi Flight Stack Watchdog (Point-LIO + bag recorder)
# Must start after MAVROS so the /mavros/state topic exists to subscribe to.
# Also depends on the SSD mount so bag recording has a valid output path.
# dronepi-main.service declares Requires=drone-watchdog.service, so if this
# service fails to start or crashes unrecoverably, main.py will also be stopped
# by systemd — the correct fail-safe when the bag/postflight supervisor is gone.
#
# LED NOTE: This service no longer owns GPIO. LED state is written to
# /tmp/led_state.json and consumed by led.service. The watchdog does NOT
# Require= led.service — if LED fails the watchdog continues operating.
After=mavros.service mnt-ssd.mount dronepi-hotspot.service led.service
Requires=mavros.service
Wants=mnt-ssd.mount dronepi-hotspot.service led.service

[Service]
Type=simple
User=dronepi
Environment="HOME=/home/dronepi"

# WorkingDirectory set to /tmp so any transient file operations
# (including LED state file writes) have a writable working directory.
WorkingDirectory=/tmp

# Source ROS 2 before running the watchdog so rclpy and mavros_msgs
# are importable. The watchdog launches Point-LIO and the bag recorder
# as subprocesses with their own source calls.
ExecStart=/bin/bash -c "\
    source /opt/ros/jazzy/setup.bash && \
    source /home/dronepi/unitree_lidar_project/RPI5/ros2_ws/install/setup.bash && \
    python3 /home/dronepi/unitree_lidar_project/unitree_drone_mapper/flight/drone_watchdog.py"

# Remove lock file on watchdog stop or crash. Prevents a stale manual_scan
# lock from blocking the next boot if the watchdog dies mid-session.
# main.py also calls clear_lock() on startup as a second guard.
ExecStopPost=/bin/rm -f /tmp/dronepi_mission.lock

# Restart the watchdog if it crashes, but not on a clean stop (e.g. systemctl stop).
Restart=on-failure
RestartSec=5

# Allow time for the watchdog to stop Point-LIO and close the bag cleanly
# before systemd sends SIGKILL. Bag close takes up to 5s (GRACEFUL_KILL_S).
TimeoutStopSec=20
KillSignal=SIGINT
KillMode=control-group

StandardOutput=journal
StandardError=journal
SyslogIdentifier=drone-watchdog

[Install]
WantedBy=multi-user.target
